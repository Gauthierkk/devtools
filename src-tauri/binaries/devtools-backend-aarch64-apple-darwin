#!/usr/bin/env python3
"""DevTools backend sidecar launcher."""
import sys
import os

# Walk up from script location to find the project root (contains backend/)
script_dir = os.path.dirname(os.path.abspath(__file__))
search = script_dir
for _ in range(6):
    candidate = os.path.join(search, "backend", "main.py")
    if os.path.isfile(candidate):
        break
    search = os.path.dirname(search)
backend_dir = os.path.join(search, "backend")
sys.path.insert(0, backend_dir)

# Add venv site-packages so dependencies (psutil, etc.) are available
venv_site = os.path.join(backend_dir, ".venv", "lib")
if os.path.isdir(venv_site):
    for d in os.listdir(venv_site):
        sp = os.path.join(venv_site, d, "site-packages")
        if os.path.isdir(sp):
            sys.path.insert(0, sp)

from main import main
main()
